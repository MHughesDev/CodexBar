<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:mp="http://schemas.microsoft.com/appx/2014/phone/manifest"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap5="http://schemas.microsoft.com/appx/manifest/uap/windows10/5"
  xmlns:desktop="http://schemas.microsoft.com/appx/manifest/desktop/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="mp uap uap5 desktop rescap">

  <Identity
    Name="CodexBar"
    Publisher="CN=CodexBar"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <mp:PhoneIdentity PhoneProductId="7B7B5C74-4C2A-4A3D-8B5E-1A2B3C4D5E6F" PhonePublisherId="00000000-0000-0000-0000-000000000000" />

  <Properties>
    <DisplayName>CodexBar</DisplayName>
    <PublisherDisplayName>CodexBar</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.19041.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App"
      Executable="$targetnametoken$.exe"
      EntryPoint="$targetentrypoint$">
      <uap:VisualElements
        DisplayName="CodexBar"
        Description="AI provider usage tracker"
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile Wide310x150Logo="Assets\Wide310x150Logo.png" />
        <uap:SplashScreen Image="Assets\SplashScreen.png" />
      </uap:VisualElements>
      <Extensions>
        <!-- Launch at login via OS Startup Apps settings; disabled by default, toggled by the app -->
        <desktop:Extension Category="windows.startupTask">
          <desktop:StartupTask
            TaskId="CodexBarStartup"
            Enabled="false"
            DisplayName="CodexBar"
            ExecutionType="windows.fullTrustApplication" />
        </desktop:Extension>
        <!-- URI scheme for deep-linking from toast notifications -->
        <uap5:Extension Category="windows.protocol">
          <uap5:Protocol Name="codexbar">
            <uap5:DisplayName>CodexBar</uap5:DisplayName>
          </uap5:Protocol>
        </uap5:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for WinUI 3 packaged apps running outside the AppContainer -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
