<Window
    x:Class="CodexBar.Shell.Flyout.FlyoutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CodexBar.Shell.Flyout">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
          CornerRadius="8"
          Padding="12">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="CodexBar"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   Margin="0,0,0,8" />

        <!-- Provider list -->
        <ListView Grid.Row="1"
                  x:Name="ProviderList"
                  SelectionMode="None"
                  MinHeight="100"
                  MaxHeight="480">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:ProviderCardViewModel">
                    <local:ProviderCardView DataContext="{Binding}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <TextBlock x:Name="LastUpdatedLabel"
                       VerticalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       FontSize="11"
                       Margin="0,0,12,0" />
            <Button x:Name="RefreshButton"
                    Content="↺"
                    ToolTipService.ToolTip="Refresh now"
                    Click="RefreshButton_Click" />
        </StackPanel>

    </Grid>
</Window>
