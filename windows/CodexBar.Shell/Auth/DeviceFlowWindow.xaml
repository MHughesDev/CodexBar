<Window
    x:Class="CodexBar.Shell.Auth.DeviceFlowWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="InstructionText"
                   Grid.Row="0"
                   TextWrapping="Wrap"
                   Text="Visit the link below and enter your device code:" />

        <HyperlinkButton x:Name="VerificationLink"
                         Grid.Row="1"
                         Click="VerificationLink_Click" />

        <TextBlock x:Name="UserCodeText"
                   Grid.Row="2"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   FontFamily="Consolas" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right">
            <Button x:Name="CopyButton"
                    Content="Copy Code"
                    Click="CopyButton_Click" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
